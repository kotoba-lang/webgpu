;; babashka task runner for kami-webgpu. The .cljc domain interpreters are the same source
;; the web (CLJS) and JVM (here) run. `bb verify` stays inside this CLJ/EDN repo.
;; kami.wgsl SSoT lives in sibling kotoba-lang/wgsl (ADR-2607102200)
{:paths ["src" "test" "../expr/src" "../wgsl/src" "../sprite-gpu/src" "../sprite2d/src" "../sky/src" "../shaders/src" "../render-shaders/src" "../scene2d/src" "../gpu/src" "../webgl/src" "../dance/src" "../physics/src" "../fsm/src" "../netsync/src" "../pipelines/src" "../level/src" "../host/src" "../playwright/src" "../cartpole-math/src"]
 :tasks
 {
  render-test {:doc "Headless-WebGL2 GPU-2D render: the sprite-SDF pass actually draws (pixel readback)." :task (do (load-file "scripts/gen_glsl.clj") (load-file "test/playwright_render_test.clj") (load-file "test/playwright_anim_test.clj") (load-file "test/playwright_sky_text_test.clj") (load-file "test/playwright_frame_test.clj") (load-file "test/playwright_rect_extent_test.clj") (load-file "test/playwright_mesh_test.clj"))}
  webgl-test {:doc "Headless-WebGL2 (playwright-clj) test: the EDN-generated GLSL links in a real browser." :task (do (load-file "scripts/gen_glsl.clj") (load-file "test/playwright_webgl_test.clj"))}
  gen-pipeline-specs {:doc "kami.pipelines EDN → fixtures/pipeline_specs.edn (--write / --strict)." :task (load-file "scripts/gen_pipeline_specs.clj")}
  gen-glsl {:doc "kami.wgsl EDN → WGSL → naga → GLSL ES 3.00 (WebGL2) for the web shaders." :task (load-file "scripts/gen_glsl.clj")}
  gen-wgsl    {:doc "Write fixtures/lit-shader.wgsl from kami.shaders + report native parity." :task (load-file "scripts/gen_wgsl.clj")}
  wgsl-parity {:doc "Check web↔native lit-shader parity (--strict throws)." :task (binding [*command-line-args* (vec *command-line-args*)] (load-file "scripts/gen_wgsl.clj"))}
  gen-compute-golden {:doc "Regenerate fixtures/cartpole-compute-{step.wgsl,golden.json} from CLJC math + kami.physics-compute emit (needs sibling ../kami-engine). Assert no drift with `bb gen-compute-golden && git diff --exit-code`."
                      :task (shell "bb" "--classpath" "../kami-engine/kami-engine-sdk-clj/src:src" "-f" "scripts/gen_compute_golden.clj")}
  test   {:doc  "Run the .cljc domain-interpreter unit tests on the JVM (cross-platform correctness)."
          :task (do (load-file "test/domains_bb_test.clj")
                     (load-file "test/sprite2d_layout_test.clj")
                     (load-file "test/geometry_test.clj")
                     (load-file "test/wgsl_test.clj")
                     (load-file "test/shader_test.clj")
                     (load-file "test/render_shader_test.clj") (load-file "test/render_naga_test.clj") (load-file "test/pipeline_specs_test.clj")
                     (load-file "test/gpu_test.clj")
                     (load-file "test/sprite_gpu_test.clj")
                     (load-file "test/webgl_test.clj")
                     (load-file "test/compute_golden_test.clj"))}

  verify {:doc     "Run repository-local CLJ/EDN surfaces: JVM .cljc tests."
          :depends [test]
          :task    (println "\n✓ repository-local CLJ/EDN surfaces green")}}}
